{
    "metadata": {
      "name": "lb-api-int-west",
      "disable": false
    },
    "spec": {
      "domains": [
        "remote-web.de1chk1nd-mcn.aws"
      ],
      "http": {
        "dns_volterra_managed": false,
        "port": 80
      },
      "advertise_custom": {
        "advertise_where": [
          {
            "virtual_site": {
              "network": "SITE_NETWORK_INSIDE",
              "virtual_site": {
                "tenant": "${XC_TENANT}",
                "namespace": "shared",
                "name": "${STUDENT}-eu-west-sites",
                "kind": "virtual_site"
              }
            },
            "use_default_port": {}
          }
        ]
      },
      "default_route_pools": [
        {
          "pool": {
            "tenant": "${XC_TENANT}",
            "namespace": "${NAMESPACE}",
            "name": "origin-nginx-aws-eu-central-1",
            "kind": "origin_pool"
          },
          "weight": 1,
          "priority": 1,
          "endpoint_subsets": {}
        }
      ],
      "app_firewall": {
        "tenant": "${XC_TENANT}",
        "namespace": "${NAMESPACE}",
        "name": "${STUDENT}-mcn-default-waf",
        "kind": "app_firewall"
      },
      "add_location": true,
      "no_challenge": {},
      "user_id_client_ip": {},
      "disable_rate_limit": {},
      "service_policies_from_namespace": {},
      "round_robin": {},
      "disable_trust_client_ip_headers": {},
      "disable_malicious_user_detection": {},
      "disable_api_discovery": {},
      "disable_bot_defense": {},
      "default_sensitive_data_policy": {},
      "disable_api_definition": {},
      "disable_ip_reputation": {},
      "disable_client_side_defense": {},
      "system_default_timeouts": {},
      "disable_threat_mesh": {},
      "l7_ddos_action_default": {}
    }
  }