{
    "metadata": {
      "name": "lb-${STUDENT}-jwt",
      "disable": false
    },
    "spec": {
      "domains": [
        "jwt.${STUDENT}.xc-mcn-lab.aws"
      ],
      "https": {
        "http_redirect": true,
        "add_hsts": false,
        "port": 443,
        "default_header": {},
        "enable_path_normalize": {},
        "non_default_loadbalancer": {},
        "header_transformation_type": {
          "legacy_header_transformation": {}
        },
        "connection_idle_timeout": 120000,
        "tls_cert_params": {
          "tls_config": {
            "default_security": {}
          },
          "certificates": [
            {
              "tenant": "${XC_TENANT}",
              "namespace": "${NAMESPACE}",
              "name": "tls-${STUDENT}-jwt",
              "kind": "certificate"
            }
          ],
          "no_mtls": {}
        },
        "http_protocol_options": {
          "http_protocol_enable_v1_v2": {}
        },
        "coalescing_options": {
          "default_coalescing": {}
        }
      },
      "advertise_on_public_default_vip": {},
      "default_route_pools": [
        {
          "pool": {
            "tenant": "${XC_TENANT}",
            "namespace": "${NAMESPACE}",
            "name": "origin-docker-echossl-aws-eu-central-1",
            "kind": "origin_pool"
          },
          "weight": 1,
          "priority": 1,
          "endpoint_subsets": {}
        },
        {
          "pool": {
            "tenant": "${XC_TENANT}",
            "namespace": "${NAMESPACE}",
            "name": "origin-docker-echossl-aws-eu-west-1",
            "kind": "origin_pool"
          },
          "weight": 1,
          "priority": 1,
          "endpoint_subsets": {}
        }
      ],
      "app_firewall": {
        "tenant": "${XC_TENANT}",
        "namespace": "${NAMESPACE}",
        "name": "${STUDENT}-mcn-default-waf",
        "kind": "app_firewall"
      },
      "jwt_validation": {
        "target": {
          "all_endpoint": {}
        },
        "token_location": {
          "bearer_token": {}
        },
        "action": {
          "block": {}
        },
        "jwks_config": {
          "cleartext": "string:///${JWKS_B64}"
        },
        "reserved_claims": {
          "issuer": "https://lab.${STUDENT}.xc-mcn-lab.aws",
          "audience": {
            "audiences": [
              "https://jwt.${STUDENT}.xc-mcn-lab.aws"
            ]
          },
          "validate_period_enable": {}
        },
        "mandatory_claims": {
          "claim_names": [
            "iss",
            "aud",
            "sub",
            "exp"
          ]
        }
      },
      "add_location": true,
      "no_challenge": {},
      "user_id_client_ip": {},
      "disable_rate_limit": {},
      "service_policies_from_namespace": {},
      "round_robin": {},
      "disable_trust_client_ip_headers": {},
      "disable_malicious_user_detection": {},
      "disable_api_discovery": {},
      "disable_bot_defense": {},
      "default_sensitive_data_policy": {},
      "disable_api_definition": {},
      "disable_ip_reputation": {},
      "disable_client_side_defense": {},
      "system_default_timeouts": {},
      "disable_threat_mesh": {},
      "l7_ddos_action_default": {},
      "disable_malware_protection": {}
    }
  }
