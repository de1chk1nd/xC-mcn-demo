{
    "metadata": {
      "name": "lb-k8s-central",
      "disable": false
    },
    "spec": {
      "domains": [
        "k8s-central.${STUDENT}.xc-mcn-lab.aws"
      ],
      "https": {
        "http_redirect": true,
        "add_hsts": false,
        "port": 443,
        "default_header": {},
        "enable_path_normalize": {},
        "non_default_loadbalancer": {},
        "header_transformation_type": {
          "legacy_header_transformation": {}
        },
        "connection_idle_timeout": 120000,
        "tls_cert_params": {
          "tls_config": {
            "default_security": {}
          },
          "certificates": [
            {
              "tenant": "${XC_TENANT}",
              "namespace": "${NAMESPACE}",
              "name": "tls-${STUDENT}-k8s-central",
              "kind": "certificate"
            }
          ],
          "no_mtls": {}
        },
        "http_protocol_options": {
          "http_protocol_enable_v1_v2": {}
        },
        "coalescing_options": {
          "default_coalescing": {}
        }
      },
      "advertise_on_public_default_vip": {},
      "default_route_pools": [
        {
          "pool": {
            "tenant": "${XC_TENANT}",
            "namespace": "${NAMESPACE}",
            "name": "origin-k8s-central",
            "kind": "origin_pool"
          },
          "weight": 1,
          "priority": 1,
          "endpoint_subsets": {}
        }
      ],
      "app_firewall": {
        "tenant": "${XC_TENANT}",
        "namespace": "${NAMESPACE}",
        "name": "${STUDENT}-mcn-default-waf",
        "kind": "app_firewall"
      },
      "add_location": true,
      "no_challenge": {},
      "user_id_client_ip": {},
      "disable_rate_limit": {},
      "service_policies_from_namespace": {},
      "round_robin": {},
      "disable_trust_client_ip_headers": {},
      "disable_malicious_user_detection": {},
      "disable_api_discovery": {},
      "disable_bot_defense": {},
      "default_sensitive_data_policy": {},
      "disable_api_definition": {},
      "disable_ip_reputation": {},
      "disable_client_side_defense": {},
      "system_default_timeouts": {},
      "disable_threat_mesh": {},
      "l7_ddos_action_default": {}
    }
  }
